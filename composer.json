{
    "name": "dwgebler/encryption",
    "description": "Encryption wrapper for PHP using libsodium — simple API for symmetric and asymmetric encryption, password hashing, digital signing, and message authentication.",
    "type": "library",
    "license": "MIT",
    "autoload": {
        "psr-4": {
            "Gebler\\Encryption\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Gebler\\Encryption\\Tests\\": "tests/"
        }
    },
    "authors": [
        {
            "name": "David Gebler",
            "email": "me@davegebler.com"
        }
    ],
    "require": {
        "php": "^8.2",
        "ext-sodium": "*"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0",
        "phpstan/phpstan": "^1.11",
        "vimeo/psalm": "^6.0",
        "squizlabs/php_codesniffer": "^3.10",
        "psalm/plugin-phpunit": "^0.19"
    },
    "scripts": {
        "test": "phpunit",
        "stan": "phpstan analyse",
        "psalm": "psalm",
        "cs": "phpcs",
        "check": ["@cs", "@stan", "@psalm", "@test"]
    }
}
